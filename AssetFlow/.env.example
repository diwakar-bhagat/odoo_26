# Required — Neon Postgres connection string (used by src/lib/db.ts)
DATABASE_URL=

# Required in production — used to sign NextAuth session JWTs (src/lib/auth-config.ts).
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# Required in production — the canonical URL of this deployment (NextAuth callback base).
NEXTAUTH_URL=http://localhost:3000

# Optional — Upstash Redis REST cache. If unset, caching is silently disabled (src/lib/redis.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — only used by the (unused-by-AssetFlow) design gallery leftover component.
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=
